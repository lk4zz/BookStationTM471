// Step 3 (taste map): historical taste vectors for trajectory plots.
// Rows are written from tasteService after each blend (throttled).
model UserTasteSnapshot {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasteProfile String   @db.LongText
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}
