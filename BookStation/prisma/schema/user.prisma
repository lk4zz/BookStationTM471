model User {
    id              Int @id @default(autoincrement())
    name            String
    email           String @unique
    password        String
    coinBalance     Int @default(0)
    bio             String?
    profileImage    String?
    tasteProfile    String? @db.LongText
    
    roleId          Int 
    role            UserRole @relation(fields: [roleId], references: [id])
    
    aiAccessExpires DateTime?
    
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    books           Books[]
    views           BookViews[]
    ratings         Rating[]
    chapterUnlocks  ChapterUnlocks[]
    libraries       Library[]
    comments        Comments[]
    transactions    TransactionLedger[]
    following       Followers[] @relation("FollowerRelation")
    followers       Followers[] @relation("FollowingRelation")
    readingProgress ReadingProgress[]
    pageChunks      PageChunk[]
    applications AuthorApplication[]
}