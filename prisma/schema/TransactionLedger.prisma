model TransactionLedger {
  id          Int      @id @default(autoincrement())
  userId      Int
  amount      Int      // Positive (+) for buying/earning coins, Negative (-) for spending
  type        String   // e.g., 'PURCHASE_COINS', 'UNLOCK_CHAPTER'
  referenceId Int?     // e.g., The chapterId they unlocked
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@map("transaction_ledger")
}